page {
  background:
    radial-gradient(circle at 12% 10%, rgba(20, 184, 166, 0.14) 0%, rgba(20, 184, 166, 0) 30%),
    radial-gradient(circle at 88% 14%, rgba(3, 105, 161, 0.12) 0%, rgba(3, 105, 161, 0) 24%),
    linear-gradient(180deg, #f8fcfc 0%, #f1f8f9 46%, #edf5f9 100%);
  color: #163b40;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
button,
swiper,
swiper-item {
  box-sizing: border-box;
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 32rpx 24rpx 60rpx;
  overflow: hidden;
}

.page-backdrop {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.page-backdrop.top {
  top: -140rpx;
  right: -110rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(20, 184, 166, 0.18) 0%, rgba(20, 184, 166, 0.05) 46%, rgba(20, 184, 166, 0) 76%);
}

.page-backdrop.bottom {
  left: -120rpx;
  bottom: 90rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(3, 105, 161, 0.16) 0%, rgba(3, 105, 161, 0.04) 52%, rgba(3, 105, 161, 0) 76%);
}

.content-stack {
  position: relative;
  z-index: 1;
}

.card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.95);
  border: 2rpx solid rgba(19, 78, 74, 0.08);
  border-radius: 32rpx;
  box-shadow:
    0 22rpx 46rpx rgba(15, 42, 47, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
}

.card-wash {
  position: absolute;
  top: 0;
  right: 0;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle at top right, rgba(20, 184, 166, 0.12) 0%, rgba(20, 184, 166, 0) 72%);
  pointer-events: none;
}

.kicker {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.08);
  border: 2rpx solid rgba(15, 118, 110, 0.1);
  color: #0f766e;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.title {
  color: #163b40;
  font-size: 52rpx;
  line-height: 1.14;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.subtitle {
  color: #557176;
  font-size: 28rpx;
  line-height: 1.78;
}

.section-kicker {
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.section-heading {
  margin-top: 16rpx;
  color: #163b40;
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 700;
}

.section-copy {
  margin-top: 14rpx;
  color: #627b7f;
  font-size: 26rpx;
  line-height: 1.72;
}

.button-primary,
.button-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.button-primary {
  height: 92rpx;
  background: linear-gradient(135deg, #0f766e 0%, #0369a1 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 28rpx rgba(3, 105, 161, 0.22);
}

.button-secondary {
  height: 84rpx;
  border: 2rpx solid rgba(19, 78, 74, 0.12);
  background: rgba(255, 255, 255, 0.92);
  color: #22555b;
  box-shadow: 0 10rpx 20rpx rgba(15, 42, 47, 0.05);
}

.button-primary:active,
.button-secondary:active {
  transform: translateY(2rpx);
}

.loading-card {
  padding: 42rpx 34rpx;
}

.loading-title {
  margin-top: 18rpx;
  color: #163b40;
  font-size: 38rpx;
  line-height: 1.32;
  font-weight: 700;
}

.loading-copy {
  margin-top: 16rpx;
  color: #627b7f;
  font-size: 28rpx;
  line-height: 1.78;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(15, 118, 110, 0.12);
  color: #22555b;
  font-size: 22rpx;
  font-weight: 600;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #14b8a6;
}

.reveal-up {
  animation: revealUp 560ms ease both;
}

.delay-1 {
  animation-delay: 90ms;
}

.delay-2 {
  animation-delay: 180ms;
}

.delay-3 {
  animation-delay: 260ms;
}

@keyframes revealUp {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
