.progress {
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
}

.progress-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.progress-title {
  margin-top: 18rpx;
  color: #163b40;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
}

.progress-side {
  text-align: right;
}

.progress-total {
  color: #1f5b60;
  font-size: 26rpx;
  font-weight: 700;
}

.progress-status {
  margin-top: 10rpx;
  color: #71888c;
  font-size: 22rpx;
}

.progress-bar {
  height: 14rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: rgba(20, 184, 166, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #0f766e 0%, #0369a1 100%);
  box-shadow: 0 0 16rpx rgba(3, 105, 161, 0.2);
}

.progress-foot {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 16rpx;
}

.progress-foot-copy {
  color: #6b8387;
  font-size: 22rpx;
  line-height: 1.6;
}

.question-card {
  padding: 30rpx 26rpx;
}

.question-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.question-id,
.dimension-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.08);
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.question-text {
  color: #163b40;
  font-size: 40rpx;
  line-height: 1.52;
  font-weight: 700;
}

.question-tip {
  margin-top: 16rpx;
  color: #627b7f;
  font-size: 25rpx;
  line-height: 1.72;
}

.choice-guide {
  margin-top: 24rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(240, 253, 250, 0.94) 0%, rgba(255, 255, 255, 0.92) 100%);
  border: 2rpx solid rgba(15, 118, 110, 0.08);
}

.choice-guide-title {
  color: #164e4a;
  font-size: 24rpx;
  font-weight: 700;
}

.choice-guide-copy {
  margin-top: 10rpx;
  color: #688084;
  font-size: 24rpx;
  line-height: 1.68;
}

.options {
  margin-top: 26rpx;
}

.option {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(250, 253, 253, 0.98);
  border: 2rpx solid rgba(19, 78, 74, 0.1);
  box-shadow: 0 12rpx 24rpx rgba(15, 42, 47, 0.04);
}

.option-active {
  border-color: rgba(15, 118, 110, 0.34);
  background: linear-gradient(180deg, rgba(238, 251, 249, 1) 0%, rgba(250, 253, 253, 0.98) 100%);
  box-shadow: 0 16rpx 28rpx rgba(15, 118, 110, 0.08);
}

.option-key {
  width: 60rpx;
  height: 60rpx;
  margin-top: 2rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ecfdfa 0%, #d8f5ef 100%);
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-body {
  flex: 1;
}

.option-label {
  color: #4f6d72;
  font-size: 22rpx;
  font-weight: 700;
}

.option-text {
  margin-top: 10rpx;
  color: #284a50;
  font-size: 29rpx;
  line-height: 1.72;
}

.option-check {
  min-width: 72rpx;
  padding-top: 6rpx;
  color: #779093;
  font-size: 22rpx;
  font-weight: 600;
  text-align: right;
}

.option-check-active {
  color: #0369a1;
}

.submit-note {
  margin-top: 24rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(239, 248, 250, 0.96) 0%, rgba(255, 255, 255, 0.96) 100%);
  border: 2rpx solid rgba(3, 105, 161, 0.08);
  color: #567378;
  font-size: 24rpx;
  line-height: 1.72;
  text-align: center;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.nav-btn {
  flex: 1;
}

.nav-btn-disabled {
  opacity: 0.55;
}

.modal-mask,
.confirm-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  background:
    radial-gradient(circle at 18% 14%, rgba(20, 184, 166, 0.12) 0%, rgba(20, 184, 166, 0) 28%),
    radial-gradient(circle at 82% 10%, rgba(3, 105, 161, 0.14) 0%, rgba(3, 105, 161, 0) 24%),
    rgba(7, 19, 28, 0.52);
  backdrop-filter: blur(14rpx);
}

.confirm-mask {
  z-index: 21;
  padding: 48rpx;
}

.login-card {
  width: 100%;
  max-width: 620rpx;
  padding: 46rpx 34rpx 36rpx;
  text-align: center;
  border-color: rgba(255, 255, 255, 0.4);
  background: linear-gradient(180deg, rgba(252, 255, 255, 0.98) 0%, rgba(245, 250, 252, 0.96) 100%);
  box-shadow:
    0 26rpx 58rpx rgba(9, 25, 36, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.login-close {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(19, 78, 74, 0.08);
  box-shadow: 0 10rpx 18rpx rgba(15, 42, 47, 0.08);
}

.login-close-icon {
  color: #6a8087;
  font-size: 34rpx;
  line-height: 1;
}

.login-avatar {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.login-avatar-mark {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  background: #2f7e87;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 18rpx 34rpx rgba(47, 126, 135, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.22);
}

.login-title {
  margin-top: 22rpx;
  color: #163b40;
  font-size: 38rpx;
  line-height: 1.32;
  font-weight: 700;
}

.login-desc {
  margin-top: 12rpx;
  color: #5f787f;
  font-size: 24rpx;
  line-height: 1.7;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 30rpx;
  padding: 20rpx 20rpx 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(243, 249, 251, 0.96) 0%, rgba(255, 255, 255, 0.96) 100%);
  border: 2rpx solid rgba(19, 78, 74, 0.08);
  text-align: left;
}

.agreement-check {
  width: 36rpx;
  height: 36rpx;
  margin-top: 2rpx;
  border-radius: 50%;
  border: 2rpx solid #c9d8da;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}

.agreement-check-active {
  border-color: #3793bf;
  background: #3793bf;
  box-shadow: 0 8rpx 18rpx rgba(55, 147, 191, 0.2);
}

.agreement-check-icon {
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
}

.agreement-text {
  color: #5f777d;
  font-size: 24rpx;
  line-height: 1.65;
}

.agreement-link {
  color: #035f8f;
  font-weight: 600;
}

.phone-auth-error {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255, 246, 241, 0.96) 0%, rgba(255, 251, 249, 0.96) 100%);
  border: 2rpx solid rgba(201, 93, 69, 0.1);
  color: #bc5b46;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: left;
}

.login-action {
  width: 100%;
  margin-top: 28rpx;
  height: 94rpx;
  border-radius: 999rpx;
  background: #2f7e87;
  box-shadow:
    0 18rpx 30rpx rgba(47, 126, 135, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.login-action[loading] {
  opacity: 0.92;
}

.login-action::after,
.confirm-btn::after {
  border: 0;
}

.login-secondary {
  margin-top: 22rpx;
  color: #789096;
  font-size: 24rpx;
  line-height: 1.6;
}

.confirm-card {
  width: 100%;
  max-width: 520rpx;
  padding: 34rpx 0 0;
  overflow: hidden;
  border-color: rgba(255, 255, 255, 0.36);
  background: linear-gradient(180deg, rgba(252, 255, 255, 0.98) 0%, rgba(245, 250, 252, 0.96) 100%);
  box-shadow:
    0 28rpx 60rpx rgba(9, 25, 36, 0.24),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.confirm-title {
  text-align: center;
  color: #163b40;
  font-size: 34rpx;
  font-weight: 700;
}

.confirm-copy {
  margin-top: 18rpx;
  padding: 0 32rpx 28rpx;
  color: #5f787f;
  font-size: 26rpx;
  line-height: 1.75;
  text-align: center;
}

.confirm-actions {
  display: flex;
  border-top: 2rpx solid rgba(19, 78, 74, 0.08);
}

.confirm-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  background: transparent;
  color: #163b40;
  font-size: 28rpx;
  font-weight: 600;
}

.confirm-btn.cancel {
  border-right: 2rpx solid rgba(19, 78, 74, 0.08);
  color: #7d9195;
}

.confirm-btn.confirm {
  color: #2f7e87;
  background: rgba(231, 245, 247, 0.96);
}
