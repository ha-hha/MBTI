.progress {
  padding: 28rpx 26rpx;
  margin-bottom: 22rpx;
}

.progress-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.progress-title {
  margin-top: 18rpx;
  color: #163b40;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
}

.progress-side {
  text-align: right;
}

.progress-total {
  color: #1f5b60;
  font-size: 26rpx;
  font-weight: 700;
}

.progress-status {
  margin-top: 10rpx;
  color: #71888c;
  font-size: 22rpx;
}

.progress-bar {
  height: 14rpx;
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: rgba(20, 184, 166, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #0f766e 0%, #0369a1 100%);
  box-shadow: 0 0 16rpx rgba(3, 105, 161, 0.2);
}

.progress-foot {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 16rpx;
}

.progress-foot-copy {
  color: #6b8387;
  font-size: 22rpx;
  line-height: 1.6;
}

.question-card {
  padding: 30rpx 26rpx;
}

.question-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.question-id,
.dimension-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.08);
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.question-text {
  color: #163b40;
  font-size: 40rpx;
  line-height: 1.52;
  font-weight: 700;
}

.question-tip {
  margin-top: 16rpx;
  color: #627b7f;
  font-size: 25rpx;
  line-height: 1.72;
}

.choice-guide {
  margin-top: 24rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(240, 253, 250, 0.94) 0%, rgba(255, 255, 255, 0.92) 100%);
  border: 2rpx solid rgba(15, 118, 110, 0.08);
}

.choice-guide-title {
  color: #164e4a;
  font-size: 24rpx;
  font-weight: 700;
}

.choice-guide-copy {
  margin-top: 10rpx;
  color: #688084;
  font-size: 24rpx;
  line-height: 1.68;
}

.options {
  margin-top: 26rpx;
}

.option {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(250, 253, 253, 0.98);
  border: 2rpx solid rgba(19, 78, 74, 0.1);
  box-shadow: 0 12rpx 24rpx rgba(15, 42, 47, 0.04);
}

.option-active {
  border-color: rgba(15, 118, 110, 0.34);
  background: linear-gradient(180deg, rgba(238, 251, 249, 1) 0%, rgba(250, 253, 253, 0.98) 100%);
  box-shadow: 0 16rpx 28rpx rgba(15, 118, 110, 0.08);
}

.option-key {
  width: 60rpx;
  height: 60rpx;
  margin-top: 2rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ecfdfa 0%, #d8f5ef 100%);
  color: #0f766e;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-body {
  flex: 1;
}

.option-label {
  color: #4f6d72;
  font-size: 22rpx;
  font-weight: 700;
}

.option-text {
  margin-top: 10rpx;
  color: #284a50;
  font-size: 29rpx;
  line-height: 1.72;
}

.option-check {
  min-width: 72rpx;
  padding-top: 6rpx;
  color: #779093;
  font-size: 22rpx;
  font-weight: 600;
  text-align: right;
}

.option-check-active {
  color: #0369a1;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.nav-btn {
  flex: 1;
}

.nav-btn-disabled {
  opacity: 0.55;
}
