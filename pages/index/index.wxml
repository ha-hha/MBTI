<view class="page home-page">
  <view class="page-backdrop top"></view>
  <view class="page-backdrop bottom"></view>

  <view wx:if="{{loading}}" class="loading-card card reveal-up">
    <view class="card-wash"></view>
    <view class="kicker">MBTI HUMAN PREMIUM</view>
    <view class="loading-title">正在为你准备测评入口</view>
    <view class="loading-copy">测评配置、题库和结果说明正在同步，马上就能开始。</view>
  </view>

  <view wx:elif="{{error}}" class="loading-card card reveal-up">
    <view class="card-wash"></view>
    <view class="kicker">NETWORK CHECK</view>
    <view class="loading-title">暂时没拿到测评内容</view>
    <view class="loading-copy">请检查当前网络或后端联调状态，然后重新加载一次。</view>
    <view class="button-primary home-action" bindtap="retryLoad">重新加载</view>
  </view>

  <block wx:elif="{{config}}">
    <view class="content-stack">
      <view class="hero card reveal-up">
        <view class="card-wash"></view>

        <view class="hero-top">
          <view class="kicker">AI CAREER UPGRADE</view>
          <view class="status-pill">
            <view class="status-dot"></view>
            <text>2026 职业升级特辑</text>
          </view>
        </view>

        <view class="title hero-title">{{config.themeTitle}}</view>
        <view class="hero-lead">看清你在 AI 时代最值钱的判断力、协作方式与职业升级空间。</view>
        <view class="subtitle intro">{{config.startCopy}}</view>

        <view class="trust-row">
          <view wx:for="{{trustTags}}" wx:key="*this" class="trust-tag">{{item}}</view>
        </view>

        <view class="metric-grid">
          <view wx:for="{{proofStats}}" wx:key="label" class="metric-card">
            <view class="metric-value">{{item.value}}</view>
            <view class="metric-label">{{item.label}}</view>
            <view class="metric-note">{{item.note}}</view>
          </view>
        </view>

        <view class="story-panel">
          <view class="story-head">
            <view class="story-title">为什么值得做这次测试</view>
            <view class="story-note">信息会更直接，也更贴近真实职业场景</view>
          </view>

          <swiper
            class="story-swiper"
            autoplay="{{canAutoPlayStories}}"
            circular="{{canAutoPlayStories}}"
            interval="3200"
            duration="500"
            indicator-dots="{{canAutoPlayStories}}"
            indicator-color="rgba(15, 118, 110, 0.18)"
            indicator-active-color="#0f766e"
          >
            <swiper-item wx:for="{{heroLines}}" wx:key="*this">
              <view class="story-slide">
                <view class="story-index">0{{index + 1}}</view>
                <view class="story-copy">{{item}}</view>
              </view>
            </swiper-item>
          </swiper>
        </view>

        <view class="cta-panel">
          <view class="button-primary cta" bindtap="startAssessment">开始测评</view>
          <view class="button-secondary" bindtap="openHistory">查看历史记录</view>
        </view>
      </view>

      <view class="section-card card reveal-up delay-1">
        <view class="section-kicker">VALUE MAP</view>
        <view class="section-heading">你会直接获得哪些信息</view>
        <view class="section-copy">不是泛泛而谈的性格描述，而是可用于职业判断与 AI 协作的结果。</view>

        <view class="insight-list">
          <view wx:for="{{insightCards}}" wx:key="title" class="insight-item">
            <view class="insight-index">{{item.index}}</view>
            <view class="insight-body">
              <view class="insight-title">{{item.title}}</view>
              <view class="insight-copy">{{item.copy}}</view>
            </view>
          </view>
        </view>
      </view>

      <view class="section-card card reveal-up delay-2">
        <view class="section-kicker">BEFORE / AFTER</view>
        <view class="section-heading">从“知道自己像谁”到“知道自己该怎么升级”</view>
        <view class="section-copy">这份报告的重点不是结论本身，而是帮你把结论转成行动方向。</view>

        <view class="transform-grid">
          <view wx:for="{{transformationCards}}" wx:key="stage" class="transform-card">
            <view class="transform-stage">{{item.stage}}</view>
            <view class="transform-title">{{item.title}}</view>
            <view class="transform-copy">{{item.copy}}</view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{phoneAuthVisible}}" class="modal-mask" catchtouchmove="noop">
    <view class="login-card card reveal-up">
      <view class="login-close" bindtap="closePhoneAuthModal">
        <text class="login-close-icon">×</text>
      </view>

      <view class="login-avatar">
        <view class="login-avatar-mark">AI</view>
      </view>
      <view class="login-title">MBTI 性格测试</view>
      <view class="login-desc">申请获取你的微信账号信息</view>

      <view class="agreement-row">
        <view
          class="agreement-check {{agreementChecked ? 'agreement-check-active' : ''}}"
          bindtap="toggleAgreement"
        >
          <text wx:if="{{agreementChecked}}" class="agreement-check-icon">✓</text>
        </view>
        <view class="agreement-text">
          阅读并同意
          <text class="agreement-link" bindtap="openPrivacyGuide">《用户隐私协议》</text>
        </view>
      </view>

      <view wx:if="{{phoneAuthError}}" class="phone-auth-error">{{phoneAuthError}}</view>

      <button
        wx:if="{{agreementChecked}}"
        class="button-primary login-action"
        open-type="getPhoneNumber"
        loading="{{phoneAuthSubmitting}}"
        bindtap="markAgreementAccepted"
        bindgetphonenumber="onGetPhoneNumber"
      >
        一键登录
      </button>
      <button
        wx:else
        class="button-primary login-action"
        loading="{{phoneAuthSubmitting}}"
        bindtap="handleLoginClick"
      >
        一键登录
      </button>

      <view class="login-secondary" bindtap="closePhoneAuthModal">暂不登录</view>
    </view>

    <view wx:if="{{confirmModalVisible}}" class="confirm-mask" catchtouchmove="noop">
      <view class="confirm-card card reveal-up">
        <view class="confirm-title">温馨提示</view>
        <view class="confirm-copy">
          阅读并同意
          <text class="agreement-link" bindtap="openPrivacyGuide">《用户隐私协议》</text>
        </view>
        <view class="confirm-actions">
          <view class="confirm-btn cancel" bindtap="closeConfirmModal">不同意</view>
          <button
            class="confirm-btn confirm"
            open-type="getPhoneNumber"
            loading="{{phoneAuthSubmitting}}"
            bindtap="markAgreementAccepted"
            bindgetphonenumber="onGetPhoneNumber"
          >
            同意并继续
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
