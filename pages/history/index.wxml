<view class="page history-page">
  <view wx:if="{{loading}}" class="loading">正在加载历史记录...</view>

  <view wx:elif="{{!items.length}}" class="empty-state card">
    <view class="empty-title">还没有测评记录</view>
    <view class="empty-copy">完成一次测评后，你的历史记录会出现在这里。</view>
  </view>

  <view wx:else>
    <view wx:for="{{items}}" wx:key="recordId" class="record-card card" data-recordid="{{item.recordId}}" bindtap="openRecord">
      <view class="record-head">
        <view class="record-title">{{item.assessmentName}}</view>
        <view class="record-type">{{item.mbtiType}}</view>
      </view>
      <view class="record-meta">生成时间：{{item.createdAt}}</view>
    </view>
  </view>
</view>
